[general]
title = "OpticWaveSim 1.1"
description = "Advanced Optical Wave Simulator with Grok AI"
showErrorDetails = true

[client]
toolbarMode = "viewer"

[server]
headless = true
port = 8501
enableCORS = false
enableXsrfProtection = true
runOnSave = true

[theme]
primaryColor = "#0066ff"
backgroundColor = "#0e1117"
secondaryBackgroundColor = "#161b22"
textColor = "#e6edf3"
font = "sans serif"

[logger]
level = "info"

[browser]
gatherUsageStats = false
